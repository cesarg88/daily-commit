# Public Supabase project URL. Filled in when persistence is introduced.
NEXT_PUBLIC_SUPABASE_URL=

# Public Supabase anonymous key. Filled in when persistence is introduced.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only service role key. Do not expose this to browser code.
SUPABASE_SERVICE_ROLE_KEY=

# Secret used later to protect scheduled closure endpoints.
CRON_SECRET=
